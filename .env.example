# ── LLM Provider API Keys ────────────────────────────────────────────────────
# IMPORTANT: Store your actual keys in a .env file, never in version control.
# Copy this file to .env and fill in your real keys.

GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
COHERE_API_KEY=your_cohere_api_key_here

# OpenAI (cost-efficient fallback) — uses gpt-4-mini by default
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-mini

# Optional: Alternative OpenAI models for testing/comparison
# OPENAI_MODEL=gpt-3.5-turbo      # Cheaper but less capable
# OPENAI_MODEL=gpt-4-turbo        # More capable but more expensive

OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/free
TOGETHER_API_KEY=your_together_api_key_here
HF_API_KEY=your_huggingface_api_key_here
OCR_SPACE_API_KEY=your_ocr_space_api_key_here

# ── Python Service (optional microservice) ────
PYTHON_SERVICE_URL=http://localhost:5000

# ── Server ────
PORT=8787
NODE_ENV=production
