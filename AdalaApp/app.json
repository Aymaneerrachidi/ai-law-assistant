{
  "expo": {
    "name": "Adala App",
    "slug": "AdalaApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "adalaapp",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Used for voice input to ask legal questions"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1510",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["RECORD_AUDIO"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1a1510",
          "dark": {
            "backgroundColor": "#1a1510"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
